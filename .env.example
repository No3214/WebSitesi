# Core app
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000
DATABASE_URI=postgresql://postgres:password@localhost:5432/kozbeyli
PAYLOAD_SECRET=replace_with_a_long_random_secret

# Booking / integrations
# HMS panelinden alinacak booking engine linkini buraya yapistir.
# Bos birakilirsa site WhatsApp fallback ile calisir (yayin engellenmez).
# Ornek/resmi HMS: https://kozbeyli-konagi.hmshotel.net/?utm_source=website&utm_medium=booking_engine
NEXT_PUBLIC_HMS_BOOKING_ENGINE_URL=https://kozbeyli-konagi.hmshotel.net/?utm_source=website&utm_medium=booking_engine
NEXT_PUBLIC_WHATSAPP_URL=https://wa.me/905322342686
# HotelRunner iptal edildi; HMS tek booking engine kaynagi.
# Rezervasyon webhook'u icin HMAC secret (legacy ad korunuyor).
HOTELRUNNER_WEBHOOK_SECRET=replace_with_webhook_secret
# Iyzico/PSP webhook'u icin ayri HMAC secret. HotelRunner/HMS secret'i ile ayni yapmayin.
IYZICO_WEBHOOK_SECRET=replace_with_iyzico_webhook_secret
# Garanti BBVA Sanal POS / 3D Secure. Gercek degerleri repo'ya yazmayin.
GARANTI_POS_MODE=test
GARANTI_MERCHANT_ID=
GARANTI_TERMINAL_ID=
GARANTI_PROVISION_USER=
GARANTI_3D_STORE_KEY=
# HMS ECC imzali webhook gonderirse SPKI PEM yapistir; bos = HMAC modu.
HMS_WEBHOOK_ES256_PUBLIC_KEY=
# B2B availability API (api/v1/availability): partner SPKI PEM.
# BOS birakilirsa endpoint 404 doner (varsayilan KAPALI - guvenli).
# Partner key olsa bile canli inventory kaynagi yoksa 503 manual_required doner.
# Sadece lokal/demo test icin production disinda true yapilabilir.
B2B_PARTNER_PUBLIC_KEY=
B2B_ALLOW_STATIC_AVAILABILITY=false

# Ucretsiz API'ler (key GEREKMEZ - bilgi amacli):
# Open-Meteo (hava), sunrise-sunset.org (gun batimi),
# frankfurter.dev (ECB kurlari), date.nager.at (TR resmi tatiller)
# Hepsi /api/local-pulse uzerinden 30dk cache ile sunulur.

# Tracking / verification
# GTM dogrulanana kadar bos birakilabilir. GTM bosken dogrudan Google tag
# fallback'i icin NEXT_PUBLIC_GA4_MEASUREMENT_ID / NEXT_PUBLIC_GOOGLE_ADS_ID kullanilir.
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
NEXT_PUBLIC_GOOGLE_ADS_ID=
NEXT_PUBLIC_META_PIXEL_ID=
# PostHog: analytics rizasi sonrasi sayfa goruntuleme + Core Web Vitals RUM.
# EU host varsayilandir; farkli bolge kullaniyorsan resmi ingest hostunu gir.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
GOOGLE_SITE_VERIFICATION=
FACEBOOK_DOMAIN_VERIFICATION=
NEXT_PUBLIC_GOOGLE_MAPS_URL=

# GA4 Measurement Protocol (server-side purchase; HMS webhook'u kullanir)
# GA4 Admin > Data Streams > Measurement Protocol API secrets
GA4_MEASUREMENT_ID=
GA4_API_SECRET=

# Meta Conversions API (server-side Purchase; HMS/iyzico webhook'u kullanir)
# Pixel ID public (NEXT_PUBLIC_META_PIXEL_ID); access token SIR'dir, yalniz buraya.
# Events Manager > Veri Kaynaklari > Pixel > Ayarlar > Conversions API > token uret.
# Bos ise Meta CAPI sessizce no-op (GA4 server-side purchase'tan bagimsiz).
META_CAPI_ACCESS_TOKEN=
# Doluysa CAPI istekleri Events Manager > Test Events'te gorunur (canli dogrulama).
# Uretimde BOS birakilir; aksi halde gercek donusumler test'e dusebilir.
META_CAPI_TEST_EVENT_CODE=

# Review orchestration — Google Business Profile (otelin KENDI dogrulanmis isletmesi).
# Hepsi bos ise google review adapter no-op (yorum cekmez). OAuth 2.0 gerekir.
GOOGLE_BUSINESS_OAUTH_CLIENT_ID=
GOOGLE_BUSINESS_OAUTH_CLIENT_SECRET=
GOOGLE_BUSINESS_OAUTH_REFRESH_TOKEN=
GOOGLE_BUSINESS_ACCOUNT_ID=
GOOGLE_BUSINESS_LOCATION_ID=
# Booking.com yorum METNI ancak yazili partner onayi varsa "true" yapilir.
# Varsayilan "false" → Booking icin yalniz puan rozeti + kaynaga link.
NEXT_PUBLIC_BOOKING_PUBLIC_APPROVAL=false

# Paylasimli rate-limit/replay (Audit T4). BOS birakilirsa in-memory
# fallback calisir (dev icin yeterli; prod'da Upstash onerilir).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Bot protection
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# HMS 'iFrame [TAM]' script yontemi (opsiyonel; set edilirse iframe yerine inline widget)
# NEXT_PUBLIC_HMS_SCRIPT_URL=https://app.hms.gen.tr/api/v1/channel/iframe/17908/kozbeyli-konagi.js
