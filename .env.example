# Kozbeyli Konağı - Environment Variables Template
# Copy this to .env.local for development or set as secrets in Railway

# PAYLOAD CMS
PAYLOAD_SECRET=your_secret_here
DATABASE_URI=postgresql://postgres:password@localhost:5432/kozbeyli
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# HOTELRUNNER INTEGRATION
NEXT_PUBLIC_HOTELRUNNER_SLUG=KOZBEYLI_KONAGI_SLUG
HOTELRUNNER_WEBHOOK_SECRET=your_webhook_secret_here

# EXTERNAL SERVICES
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
NEXT_PUBLIC_FB_PIXEL_ID=XXXXXXXXXXXXXXX
CLOUDFLARE_TURNSTILE_SITE_KEY=your_site_key_here
CLOUDFLARE_TURNSTILE_SECRET_KEY=your_secret_key_here

# AI GROWTH ENGINE (MASTER STACK)
OPENROUTER_API_KEY=YOUR_OPENROUTER_KEY_HERE
GROQ_API_KEY=YOUR_GROQ_KEY_HERE
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_KEY_HERE
GOOGLE_API_KEY=YOUR_GOOGLE_KEY_HERE

# PRODUCTION FLAGS
NODE_ENV=production
