# Core app
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000
DATABASE_URI=postgresql://postgres:password@localhost:5432/kozbeyli
PAYLOAD_SECRET=replace_with_a_long_random_secret

# Booking / integrations
NEXT_PUBLIC_HOTELRUNNER_SLUG=replace_with_hotelrunner_slug
HOTELRUNNER_WEBHOOK_SECRET=replace_with_webhook_secret

# Tracking / verification
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_META_PIXEL_ID=
GOOGLE_SITE_VERIFICATION=
FACEBOOK_DOMAIN_VERIFICATION=
GOOGLE_MAPS_URL=

# Bot protection
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# AI Concierge
AI_PROVIDER=none
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_TIMEOUT_MS=12000
AI_MAX_OUTPUT_TOKENS=500
AI_TEMPERATURE=0.4
